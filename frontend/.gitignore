# Frontend Specific .gitignore

# ============================================
# DEPENDENCIES
# ============================================

# Node modules
node_modules/

# ============================================
# BUILD OUTPUT
# ============================================

# Production build
dist/
build/

# ============================================
# LOGS
# ============================================

# npm/yarn logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ============================================
# ENVIRONMENT
# ============================================

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ============================================
# EDITOR
# ============================================

# VS Code
.vscode/*
!.vscode/extensions.json

# IDE
.idea
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ============================================
# TESTING
# ============================================

# Test coverage
coverage/
.nyc_output/

# ============================================
# CACHE
# ============================================

# Vite cache
.vite/

# TypeScript cache
*.tsbuildinfo

# ============================================
# OS
# ============================================

# macOS
.DS_Store

# Windows
Thumbs.db

# ============================================
# MISCELLANEOUS
# ============================================

# Backup files
*.bak
*.backup
*.old
